[font]
{{- if eq .chezmoi.os "linux" }}
normal = { family = "MesloLGS NF", style = "Regular" }
size = 15.0
{{- else }}
normal = { family = "MesloLGS NF", style = "Regular" }
size = 15.0
{{- end }}


# Importów nie potrzebujemy, wklejam kolory na sztywno, żeby działało od ręki.

[env]
TERM = "xterm-256color"

[window]
# Tytuł okna
title = "Alacritty"

# Marginesy wewnątrz terminala (żeby tekst nie kleił się do ramki)
padding = { x = 10, y = 10 }

# Dekoracje okna (full = standardowa belka, buttonless, none)
{{- if eq .chezmoi.os "linux" }}
decorations = "full"
{{- else }}
decorations = "none"
{{- end }}
# Przezroczystość (0.0 - niewidzialne, 1.0 - pełne tło)
# Jeśli w Neovimie włączyłeś `transparent = true`, tutaj ustaw np. 0.90 lub 0.95
opacity = 0.85
blur = false

# Startowy tryb okna
startup_mode = "Windowed"

[scrolling]
# Ile linii historii trzymać
history = 10000
multiplier = 3

# [font]
# # WAŻNE: Upewnij się, że masz zainstalowany ten font w systemie.
# # Jeśli używasz innego (np. Hack, FiraCode), zmień nazwę w cudzysłowie.
# # Musi to być wersja "Nerd Font", żebyś widział ikony w LazyVim.
# normal = { family = "JetBrainsMono Nerd Font", style = "Regular" }
# bold = { family = "JetBrainsMono Nerd Font", style = "Bold" }
# italic = { family = "JetBrainsMono Nerd Font", style = "Italic" }
# bold_italic = { family = "JetBrainsMono Nerd Font", style = "Bold Italic" }
#
# # Rozmiar czcionki
# size = 13.0

# Renderowanie fontów (często pomaga na macOS, na Linuxie można zostawić domyślne)
# use_thin_strokes = true 

[colors]
# EVERFOREST THEME
[colors.primary]
foreground = "#d3c6aa"
background = "#2d353b"

[colors.cursor]
text = "#2d353b"
cursor = "#d3c6aa"

[colors.selection]
text = "#d3c6aa"
background = "#414b51"

[colors.normal]
black = "#343f44"
red = "#e67e80"
green = "#a7c080"
yellow = "#dbbc7f"
blue = "#7fbbb3"
magenta = "#d699b6"
cyan = "#83c092"
white = "#d3c6aa"

[colors.bright]
black = "#859289"
red = "#e67e80"
green = "#a7c080"
yellow = "#dbbc7f"
blue = "#7fbbb3"
magenta = "#d699b6"
cyan = "#83c092"
white = "#d3c6aa"

