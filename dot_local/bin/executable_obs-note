#!/usr/bin/env bash

# Ścieżki
VAULT_ROOT="$HOME/notes"
INBOX_DIR="$VAULT_ROOT/00_Inbox"
TEMPLATE_FILE="$VAULT_ROOT/06_Templates/Note.md"

# Dane podstawowe
DATE=$(date +%Y-%m-%d)
TIME=$(date +%H:%M)

# Logika argumentów: $1 to treść, $2 (opcjonalnie) to tytuł
CONTENT="$1"
if [[ -n "$2" ]]; then
    TITLE="$2"
else
    TITLE="$DATE"
fi

# 1. Walidacja - musimy mieć chociaż treść
if [[ -z "$CONTENT" ]]; then
    echo "Błąd: Nie podano treści notatki."
    echo "Użycie: obs-note 'Treść' ['Opcjonalny Tytuł']"
    exit 1
fi

FILE_PATH="$INBOX_DIR/$TITLE.md"

# 2. Jeśli plik nie istnieje, utwórz go z szablonu
if [ ! -f "$FILE_PATH" ]; then
    mkdir -p "$INBOX_DIR"
    if [ -f "$TEMPLATE_FILE" ]; then
        sed -e "s/{{title}}/$TITLE/g" -e "s/{{date}}/$DATE/g" "$TEMPLATE_FILE" > "$FILE_PATH"
    else
        echo -e "# $TITLE\nData: $DATE\n\n## Notatki\n\n---\n### Relacje" > "$FILE_PATH"
    fi
fi

# 3. Przygotowanie wpisu (najnowsze na górze sekcji)
NEW_ENTRY="\n### $TIME\n$CONTENT"

# 4. Wstawianie treści pod nagłówkiem "## Notatki" za pomocą awk
awk -v entry="$NEW_ENTRY" '/## Notatki/ { print; print entry; next }1' "$FILE_PATH" > "$FILE_PATH.tmp" && mv "$FILE_PATH.tmp" "$FILE_PATH"

echo "✅ Zapisano w: $TITLE.md"

