# =======
# OBS CMD 
# =======
# Funkcja do wrzucania ostatniej komendy do notatek do obsidian 

obs-cmd() {
    local VAULT_PATH="$HOME/notes/03_Atlas"
    local CMD_FILE="$VAULT_PATH/CMD.md"
    local COMMENT="$*"
    local LAST_CMD=""

    # 1. Pobieranie z historii w zależności od powłoki
    if [ -n "$ZSH_VERSION" ]; then
        # Zsh: aktualna komenda jest już w historii (-1), bierzemy poprzednią (-2)
        LAST_CMD=$(fc -ln -1 -1 | sed -E 's/^[[:space:]]+//')
    elif [ -n "$BASH_VERSION" ]; then
        # Bash: aktualnej komendy jeszcze nie ma w historii, bierzemy ostatnią (-1)
        LAST_CMD=$(fc -ln -1 -1 | sed -E 's/^[[:space:]]+//')
    fi

    # 2. Weryfikacja (zabezpieczenie przed błędami)
    if [ -z "$LAST_CMD" ]; then
        echo "Błąd: Nie udało się pobrać ostatniej komendy."
        return 1
    fi

    # 3. Przygotowanie pliku
    if [ ! -f "$CMD_FILE" ]; then
        mkdir -p "$VAULT_PATH"
        touch "$CMD_FILE"
    fi

    # 4. Zapis do pliku
    {
        echo ""
        if [ -n "$COMMENT" ]; then
            echo "$COMMENT"
        fi
        echo '```bash'
        echo "$LAST_CMD"
        echo '```'
    } >> "$CMD_FILE"

    # 5. Potwierdzenie
    if [ -n "$COMMENT" ]; then
        echo "Zapisano z komentarzem: $LAST_CMD"
    else
        echo "Zapisano samą komendę: $LAST_CMD"
    fi
}

# ==========================================
# 🚀 Poranny Kokpit (Obsidian + Taskwarrior)
# ==========================================
today() {
    # Używamy Twojej ścieżki do notatek
    local DAILY_NOTE="$HOME/notes/01_Daily/$(date +%Y-%m-%d).md"
    
    printf "\n\033[1;36m=== 🛠️  Kokpit: $(date +%Y-%m-%d) ===\033[0m\n\n"

    # 1. Sprawdzanie Obsidiana
    if [ ! -f "$DAILY_NOTE" ]; then
        printf "\033[1;33m[!] Nie masz jeszcze dzisiejszego Daily Note.\033[0m\n"
        printf "    Otwórz Obsidiana i użyj QuickAdd, żeby zacząć dzień.\n"
    else
        printf "\033[1;32m[✓] Daily Note włączony i gotowy do logowania.\033[0m\n"
    fi

    # 2. Sprawdzanie Taskwarriora (zabezpieczenie, czy jest zainstalowany)
    if command -v task >/dev/null 2>&1; then
        printf "\n\033[1;35m🎯 Top 3 zadania na dziś:\033[0m\n"
        # task next wyświetla najważniejsze według urgency, limit:3 ucina listę
        task next limit:3 
    fi
    printf "\n"
}

# Uruchomienie funkcji tylko w trybie interaktywnym terminala
if [[ $- == *i* ]]; then
    # Tworzymy unikalną nazwę pliku z dzisiejszą datą
    FLAG_FILE="/tmp/kokpit_pokazany_$(date +%Y%m%d).flag"
    
    # Jeśli plik flaga nie istnieje, wyświetl kokpit i utwórz flagę
    if [ ! -f "$FLAG_FILE" ]; then
        today
        touch "$FLAG_FILE"
    fi
fi

obs-start() {
    # Upewnij się, że ścieżki zgadzają się z Twoim Vaultem
    local VAULT_PATH="$HOME/notes"
    local DAILY_DIR="$VAULT_PATH/01_Daily"
    local TEMPLATE_FILE="$VAULT_PATH/06_Templates/Daily_Template.md"
    local DATE_STR=$(date +%Y-%m-%d)
    local NEW_NOTE="$DAILY_DIR/$DATE_STR.md"

    # 1. Sprawdzenie czy notatka już istnieje
    if [ -f "$NEW_NOTE" ]; then
        echo "ℹ️ Dzisiejsza notatka ($DATE_STR.md) już istnieje w systemie."
        return 0
    fi

    # 2. Sprawdzenie czy istnieje szablon
    if [ ! -f "$TEMPLATE_FILE" ]; then
        echo "❌ Błąd: Nie znaleziono szablonu w $TEMPLATE_FILE"
        return 1
    fi


    # 4. Magia tworzenia pliku (awk bezpiecznie podmienia tylko 1. linijkę szablonu)
    awk -v date="$DATE_STR" '{
        if (NR == 1) {
            print "# " date
        } else {
            print $0
        }
    }' "$TEMPLATE_FILE" > "$NEW_NOTE"

    echo "✅ Wygenerowano czysty kokpit na dziś: $DATE_STR.md"
}

